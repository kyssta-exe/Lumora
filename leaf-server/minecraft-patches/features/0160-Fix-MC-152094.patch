diff --git a/net/minecraft/world/level/levelgen/structure/structures/EndCityPieces.java b/net/minecraft/world/level/levelgen/structure/structures/EndCityPieces.java
index b57fcb87498c64aa6ca862e011d22e5b7460c023..7879e5540999340bcf784c16897c6dcd645aafd0 100644
--- a/net/minecraft/world/level/levelgen/structure/structures/EndCityPieces.java
+++ b/net/minecraft/world/level/levelgen/structure/structures/EndCityPieces.java
@@ -203,12 +203,23 @@ public class EndCityPieces {
             }
 
             if (!this.shipCreated && random.nextInt(10 - counter) == 0) {
-                EndCityPieces.addHelper(
-                    pieces,
-                    EndCityPieces.addPiece(
-                        structureTemplateManager, endCityPiece, new BlockPos(-8 + random.nextInt(8), i1, -70 + random.nextInt(10)), "ship", rotation, true
-                    )
-                );
+                // Leaf start - Fix MC-152094
+                if (org.dreeam.leaf.config.modules.fixes.MCBugFix.mc152094) {
+                    EndCityPieces.addHelper(
+                        pieces,
+                        EndCityPieces.addShipWithinReferenceBounds(
+                            structureTemplateManager, endCityPiece, -8 + random.nextInt(8), i1, -70 + random.nextInt(10), rotation, pieces, TOWER_BOUNDS.get()
+                        )
+                    );
+                } else {
+                    EndCityPieces.addHelper(
+                        pieces,
+                        EndCityPieces.addPiece(
+                            structureTemplateManager, endCityPiece, new BlockPos(-8 + random.nextInt(8), i1, -70 + random.nextInt(10)), "ship", rotation, true
+                        )
+                    );
+                }
+                // Leaf end - Fix MC-152094
                 this.shipCreated = true;
             } else if (!EndCityPieces.recursiveChildren(
                 structureTemplateManager, EndCityPieces.HOUSE_TOWER_GENERATOR, counter + 1, endCityPiece, new BlockPos(-3, i1 + 1, -11), pieces, random
@@ -293,6 +304,7 @@ public class EndCityPieces {
         return endCityPiece;
     }
 
+    private static final ThreadLocal<org.dreeam.leaf.util.@org.jspecify.annotations.Nullable ReferenceBounds> TOWER_BOUNDS = new ThreadLocal<>(); // Leaf - Fix MC-152094
     public static void startHouseTower(
         StructureTemplateManager structureTemplateManager, BlockPos startPos, Rotation rotation, List<StructurePiece> pieces, RandomSource random
     ) {
@@ -306,7 +318,18 @@ public class EndCityPieces {
         endCityPiece = addHelper(pieces, addPiece(structureTemplateManager, endCityPiece, new BlockPos(-1, 0, -1), "second_floor_1", rotation, false));
         endCityPiece = addHelper(pieces, addPiece(structureTemplateManager, endCityPiece, new BlockPos(-1, 4, -1), "third_floor_1", rotation, false));
         endCityPiece = addHelper(pieces, addPiece(structureTemplateManager, endCityPiece, new BlockPos(-1, 8, -1), "third_roof", rotation, true));
-        recursiveChildren(structureTemplateManager, TOWER_GENERATOR, 1, endCityPiece, null, pieces, random);
+        // Leaf start - Fix MC-152094
+        if (org.dreeam.leaf.config.modules.fixes.MCBugFix.mc152094) {
+            try {
+                TOWER_BOUNDS.set(org.dreeam.leaf.util.ReferenceBounds.around(startPos));
+                recursiveChildren(structureTemplateManager, TOWER_GENERATOR, 1, endCityPiece, null, pieces, random);
+            } finally {
+                TOWER_BOUNDS.remove();
+            }
+        } else {
+            recursiveChildren(structureTemplateManager, TOWER_GENERATOR, 1, endCityPiece, null, pieces, random);
+        }
+        // Leaf end - Fix MC-152094
     }
 
     static EndCityPieces.EndCityPiece addHelper(List<StructurePiece> pieces, EndCityPieces.EndCityPiece piece) {
@@ -314,6 +337,49 @@ public class EndCityPieces {
         return piece;
     }
 
+    // Leaf start - Fix MC-152094
+    private static EndCityPiece addShipWithinReferenceBounds(
+        StructureTemplateManager structureTemplateManager,
+        EndCityPiece parent,
+        int localX,
+        int localY,
+        int requestedLocalZ,
+        Rotation rotation,
+        List<StructurePiece> currentBranchPieces,
+        org.dreeam.leaf.util.ReferenceBounds referenceBounds
+    ) {
+        // Throw NPE if related vanilla logic changes in future Minecraft versions
+        java.util.Objects.requireNonNull(referenceBounds);
+
+        for (int localZ = requestedLocalZ; localZ <= 0; localZ++) {
+            EndCityPiece ship = EndCityPieces.addPiece(
+                structureTemplateManager,
+                parent,
+                new BlockPos(localX, localY, localZ),
+                "ship",
+                rotation,
+                true
+            );
+
+            if (
+                referenceBounds.contains(ship.getBoundingBox())
+                    && StructurePiece.findCollisionPiece(currentBranchPieces, ship.getBoundingBox()) == null
+            ) {
+                return ship;
+            }
+        }
+        org.dreeam.leaf.config.modules.fixes.MCBugFix.LOGGER.warn("Unable to find a valid ship position, end ship will continue to generate anyway.");
+        return EndCityPieces.addPiece(
+            structureTemplateManager,
+            parent,
+            new BlockPos(localX, localY, requestedLocalZ),
+            "ship",
+            rotation,
+            true
+        );
+    }
+    // Leaf end - Fix MC-152094
+
     static boolean recursiveChildren(
         StructureTemplateManager structureTemplateManager,
         EndCityPieces.SectionGenerator sectionGenerator,
