From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OverwriteMC <artyom030803@gmail.com>
Date: Thu, 2 Apr 2026 20:10:28 +0300
Subject: [PATCH] Cache identifier toString and hash


diff --git a/net/minecraft/resources/Identifier.java b/net/minecraft/resources/Identifier.java
index ae6219185aa00a2753b0986ecf5f8456f4c2515d..484c211a577e5d8a8a379123556e933a726557b8 100644
--- a/net/minecraft/resources/Identifier.java
+++ b/net/minecraft/resources/Identifier.java
@@ -23,6 +23,10 @@ public final class Identifier implements Comparable<Identifier> {
     public static final String PAPER_NAMESPACE = "paper"; // Paper
     private final String namespace;
     private final String path;
+    // Leaf start - Cache identifier toString and hash
+    private final String identifierString;
+    private final int hash;
+    // Leaf end - Cache identifier toString and hash
 
     private Identifier(String namespace, String path) {
         assert isValidNamespace(namespace);
@@ -38,6 +42,13 @@ public final class Identifier implements Comparable<Identifier> {
         // Paper end - Validate Identifier
         this.namespace = namespace;
         this.path = path;
+        // Leaf start - Cache identifier toString and hash
+        this.identifierString = resourceLocation;
+
+        int result = this.namespace.hashCode();
+        result = 31 * result + this.path.hashCode();
+        this.hash = result;
+        // Leaf end - Cache identifier toString and hash
     }
 
     private static Identifier createUntrusted(String namespace, String path) {
@@ -130,7 +141,7 @@ public final class Identifier implements Comparable<Identifier> {
 
     @Override
     public String toString() {
-        return this.namespace + ":" + this.path;
+        return this.identifierString; // Leaf - Cache identifier toString and hash
     }
 
     @Override
@@ -140,7 +151,7 @@ public final class Identifier implements Comparable<Identifier> {
 
     @Override
     public int hashCode() {
-        return 31 * this.namespace.hashCode() + this.path.hashCode();
+        return this.hash; // Leaf - Cache identifier toString and hash
     }
 
     @Override
